{
  "family": "frontend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::327481844909:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "327481844909.dkr.ecr.ap-south-1.amazonaws.com/frontend:latest",
      "portMappings": [{"containerPort": 3000, "protocol": "tcp"}],
      "environment": [
        {"name": "BACKEND_URL", "value": "http://fullstack-alb-1754024858.ap-south-1.elb.amazonaws.com/api"}
      ],
      "essential": true
    }
  ]
}
