{
  "family": "backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::327481844909:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "327481844909.dkr.ecr.ap-south-1.amazonaws.com/backend:latest",
      "portMappings": [{"containerPort": 5000, "protocol": "tcp"}],
      "essential": true
    }
  ]
}
